root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cs,csproj,sln,props,targets}]
indent_size = 4

[*.{dart,yaml,yml,json,md}]
indent_size = 2

[*.{html,razor,css,scss}]
indent_size = 2

[*.{sh,ps1}]
end_of_line = lf
indent_size = 2

[Makefile]
indent_style = tab
