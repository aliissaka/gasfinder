# Copy to .env and fill in real values for local development

# ----- Backend -----
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__Default=Host=localhost;Port=5432;Database=gasfinder;Username=gasfinder;Password=gasfinder_dev

# ----- JWT -----
Jwt__Issuer=gasfinder
Jwt__Audience=gasfinder-clients
Jwt__SigningKey=replace-with-long-random-string-min-64-chars

# ----- Cloudflare R2 (or MinIO locally) -----
Storage__Endpoint=http://localhost:9000
Storage__AccessKey=gasfinder
Storage__SecretKey=gasfinder_dev
Storage__Bucket=gasfinder-assets
Storage__PublicBaseUrl=http://localhost:9000/gasfinder-assets

# ----- Firebase Cloud Messaging -----
Fcm__ProjectId=
Fcm__ServiceAccountJsonPath=
