{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "gasfinder",
    "Audience": "gasfinder-clients",
    "AccessTokenLifetimeDays": 30
  },
  "AppVersion": {
    "Apps": {
      "user": {
        "MinimumVersion": 1,
        "RecommendedVersion": 1,
        "Critical": false,
        "PlayStoreUrl": "https://play.google.com/store/apps/details?id=com.gasfinder.mobile_user",
        "Message": null
      },
      "retailer": {
        "MinimumVersion": 1,
        "RecommendedVersion": 1,
        "Critical": false,
        "PlayStoreUrl": "https://play.google.com/store/apps/details?id=com.gasfinder.mobile_retailer",
        "Message": null
      }
    }
  }
}
